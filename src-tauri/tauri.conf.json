{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "gc-project-app",
  "version": "0.1.1",
  "identifier": "com.mithu.gc-project-app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "gc-project-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["gcapp"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJDOTA1RDAxMjkyRjhBMjAKUldRZ2lpOHBBVjJRdk1vT1RSMElrV3VsR0kvRFpmaGFPSWdueStLSnN4SzZQYzVOclhIdXZzRWIK",
      "endpoints": [
        "https://github.com/GCStudio-COD/gc-pro-app/releases/latest/download/latest.json"
      ]
    }
  }
}
